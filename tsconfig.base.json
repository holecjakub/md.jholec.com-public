{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
    // TODO(CQ2-TOOLING): enable "exactOptionalPropertyTypes": true. Deferred —
    // it cascades into ~20+ type errors across apps/web (MarkdownPreview, Gate,
    // ConfirmForm, DocumentView, ActionBar) plus core/api.ts and cli, which is
    // beyond a low-risk hygiene sweep. Tackle as its own dedicated batch.
  }
}
